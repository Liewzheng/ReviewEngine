# Review-Engine SaaS Deployment Configuration
# Copy this file to .env and fill in your values
# ───────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════
# REQUIRED VARIABLES
# ═══════════════════════════════════════════════════════════════════════

# API Token for review-engine authentication (generate with: review-engine generate-token)
# Required when binding to non-localhost addresses
REVIEW_API_TOKEN=your-secure-api-token-here

# GitLab EE Personal Access Token
# Create at: https://your-gitlab.example.com/-/profile/personal_access_tokens
# Scopes needed: api, read_repository
GITLAB_TOKEN=glpat-your-gitlab-token-here

# GitLab Webhook Secret
# Set this when configuring the webhook in GitLab EE
# Any random string (32+ chars recommended). Generate with: openssl rand -hex 32
GITLAB_WEBHOOK_SECRET=your-webhook-secret-here

# LLM Configuration (JSON array)
# Supports OpenAI, Anthropic, Azure, and local models
# Example for OpenAI:
# LLM_CONFIG=[{"provider":"openai","model":"gpt-4o","api_key":"sk-your-key","base_url":"https://api.openai.com/v1"}]
# Example for multiple providers:
# LLM_CONFIG=[{"provider":"openai","model":"gpt-4o","api_key":"sk-..."},{"provider":"anthropic","model":"claude-3-5-sonnet-20241022","api_key":"sk-ant-..."}]
LLM_CONFIG=[{"provider":"openai","model":"gpt-4o","api_key":"your-openai-key"}]

# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL VARIABLES
# ═══════════════════════════════════════════════════════════════════════

# GitLab EE instance URL (self-hosted)
GITLAB_URL=https://gitlab.example.com

# Server port (default: 8080)
REVIEW_ENGINE_PORT=8080

# Logging level: trace, debug, info, warn, error
RUST_LOG=info

# Log format: json (for production), pretty (for development)
RUST_LOG_FORMAT=json

# Host paths for volume mounts
CONFIG_PATH=./config
REPORTS_PATH=./reports
SSH_KEY_PATH=~/.ssh

# ═══════════════════════════════════════════════════════════════════════
# EXAMPLE: GitLab.com (not EE)
# ═══════════════════════════════════════════════════════════════════════
# GITLAB_URL=https://gitlab.com
